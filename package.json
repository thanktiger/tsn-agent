{
  "name": "hibridge-agent",
  "private": true,
  "version": "0.10.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "e2e": "playwright test",
    "cargo:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "verify:skills": "node scripts/verify-skills.mjs",
    "release:prepare": "node scripts/prepare-release.mjs",
    "release:prepare:check": "node scripts/prepare-release.mjs --dry-run",
    "build:worker": "npm run verify:skills && esbuild src-node/claude-agent-worker.mjs --bundle --platform=node --format=esm --outfile=src-node/dist/claude-agent-worker.mjs && esbuild src-node/mcp/tsn-topology-server.ts --bundle --platform=node --format=esm --outfile=src-node/dist/tsn-topology-server.mjs && node scripts/copy-claude-binary.mjs",
    "tauri": "npm run build:worker && tauri",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,js,css}": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.145",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@xyflow/react": "^12.8.5",
    "echarts": "^6.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "^1.56.1",
    "@tauri-apps/cli": "^2.9.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "esbuild": "^0.27.7",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "lint-staged": "^17.0.8",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vitest": "^4.0.4"
  }
}
